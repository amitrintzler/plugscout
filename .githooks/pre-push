#!/usr/bin/env bash
set -euo pipefail

echo "🔍 pre-push: running lint, tests, and build..."

npm run lint || { echo "❌ Lint failed. Fix errors before pushing."; exit 1; }
npm run test || { echo "❌ Tests failed. Fix failures before pushing."; exit 1; }
npm run build || { echo "❌ Build failed. Fix errors before pushing."; exit 1; }

echo "✅ All checks passed."
